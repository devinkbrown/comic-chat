  "lanes": {
    "inventory": {
      "agent": "fast-inventory",
      "role": "research",
      "skills": ["comicchat-cpp26-engineering"],
      "contract": "Map only assigned files, ownership, tests, generated provenance, and platform reachability."
    },
    "research": {
      "agent": "protocol-researcher",
      "role": "research",
      "skills": ["comicchat-ircv3-compat", "comicchat-transport-security"],
      "contract": "Derive the assigned IRC contract from primary specifications and trace every legacy consumer."
    },
    "render": {
      "agent": "render-fidelity-researcher",
      "role": "research",
      "skills": ["comicchat-render-fidelity", "comicchat-icon-assets"],
      "contract": "Derive observable rendering behavior from Microsoft source and original artwork before proposing change."
    },
    "build-fix": {
      "agent": "cpp-build-fix-drafter",
      "role": "implementation",
      "skills": ["comicchat-cpp26-engineering", "comicchat-native-platforms"],
      "contract": "Draft only the smallest repair for one supplied compiler, linker, Meson, NMAKE, packaging, or CI diagnostic."
    },
    "implement": {
      "agent": "cpp-engineer",
      "role": "implementation",
      "skills": ["comicchat-cpp26-engineering"],
      "contract": "Draft one bounded test-first C++ change in the assigned linked worktree and leave execution to Codex."
    },
    "implement-protocol": {
      "agent": "cpp-engineer",
      "role": "implementation",
      "skills": ["comicchat-cpp26-engineering", "comicchat-ircv3-compat", "comicchat-transport-security"],
      "contract": "Draft one bounded IRCv3, SASL, capability, or legacy-protocol bridge change against the coverage ledger and named specification."
    },
    "implement-transport": {
      "agent": "cpp-engineer",
      "role": "implementation",
      "skills": ["comicchat-cpp26-engineering", "comicchat-transport-security"],
      "contract": "Draft one bounded libuv, mbedTLS, lifecycle, cancellation, or legacy-TCP-retirement change with a fail-closed contract."
    },
    "implement-render": {
      "agent": "cpp-engineer",
      "role": "implementation",
      "skills": ["comicchat-cpp26-engineering", "comicchat-render-fidelity"],
      "contract": "Draft one bounded renderer or composition change derived from cited Microsoft source and reproducible visual expectations."
    },
    "implement-platform": {
      "agent": "cpp-engineer",
      "role": "implementation",
      "skills": ["comicchat-cpp26-engineering", "comicchat-native-platforms"],
      "contract": "Draft one bounded native Windows, Linux, Wayland, FreeBSD, OpenBSD, Clang, Meson, or NMAKE compatibility change."
    },
    "implement-ui": {
      "agent": "cpp-engineer",
      "role": "implementation",
      "skills": ["comicchat-cpp26-engineering", "comicchat-native-ui", "comicchat-native-platforms"],
      "contract": "Draft one bounded native window, dialog, DPI, focus, keyboard, accessibility, or compositor integration change."
    },
    "implement-icons": {
      "agent": "visual-asset-engineer",
      "role": "implementation",
      "skills": ["comicchat-icon-assets", "comicchat-render-fidelity"],
      "contract": "Remake one bounded icon family from the original icon oracle as detailed scalable masters and generated platform variants."
    },
    "implement-characters": {
      "agent": "visual-asset-engineer",
      "role": "implementation",
      "skills": ["comicchat-render-fidelity", "comicchat-character-assets"],
      "contract": "Remaster one bounded complete character or pose family while preserving original anatomy, expression, silhouette, palette, and composition."
    },
    "optimize": {
      "agent": "cpp-engineer",
      "role": "implementation",
      "skills": ["comicchat-cpp26-engineering", "comicchat-performance"],
      "contract": "Draft one measurement-led performance or multicore change that preserves ownership and records the required benchmark contract."
    },
    "correctness": {
      "agent": "cpp-correctness-security-reviewer",
      "role": "review",
      "skills": ["comicchat-cpp26-engineering", "comicchat-transport-security"],
      "contract": "Review single-thread semantics, ownership, hostile-input bounds, secrets, TLS, and fail-closed behavior."
    },
    "security": {
      "agent": "cpp-correctness-security-reviewer",
      "role": "review",
      "skills": ["comicchat-transport-security", "comicchat-ircv3-compat"],
      "contract": "Audit trust boundaries, parsers, credentials, TLS authentication, downgrade behavior, and cleanup."
    },
    "concurrency": {
      "agent": "cpp-concurrency-reviewer",
      "role": "review",
      "skills": ["comicchat-cpp26-engineering", "comicchat-performance"],
      "contract": "Review loop affinity, lifecycle serialization, generations, cancellation, callbacks, queues, and restart interleavings."
    },
    "platform": {
      "agent": "cpp-native-platform-reviewer",
      "role": "review",
      "skills": ["comicchat-native-platforms", "comicchat-cpp26-engineering"],
      "contract": "Review Clang and MSVC language, ABI, build, packaging, Windows, Linux, Wayland, FreeBSD, and OpenBSD parity."
    },
    "ui": {
      "agent": "native-ui-reviewer",
      "role": "review",
      "skills": ["comicchat-native-ui", "comicchat-render-fidelity"],
      "contract": "Review faithful native window, dialog, DPI, focus, keyboard, accessibility, and compositor behavior without replacing system chrome."
    },
    "review": {
      "agent": "verification-reviewer",
      "role": "verification",
      "skills": ["comicchat-verification-release"],
      "contract": "Freshly audit whether the exact patch has causal, sanitizer, visual, native-platform, and integrated evidence."
    }
  }
