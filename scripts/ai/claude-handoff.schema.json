{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "role": {
      "enum": ["research", "implementation", "review", "verification"]
    },
    "status": {
      "enum": ["complete", "blocked"]
    },
    "summary": { "type": "string" },
    "worktree": { "type": "string" },
    "base": { "type": "string" },
    "head": { "type": "string" },
    "commit": { "type": "string" },
    "git_status": { "type": "string" },
    "diffstat": { "type": "string" },
    "patch_sha256": { "type": "string" },
    "model_report_trust": {
      "enum": ["untrusted-model-assertions"]
    },
    "scope": { "type": "string" },
    "oracle": { "type": "string" },
    "red": { "type": "string" },
    "green": { "type": "string" },
    "sanitizers": { "type": "string" },
    "artifacts": { "type": "string" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "kind": { "enum": ["model-tool", "proposed-command"] },
          "tool": {
            "enum": ["Read", "Grep", "Glob", "WebFetch", "WebSearch", "Edit", "Write", "none"]
          },
          "command": { "type": "string" },
          "exit_code": { "type": "integer" },
          "result": { "enum": ["passed", "failed", "not-run"] },
          "evidence": { "type": "string" }
        },
        "required": ["kind", "tool", "command", "exit_code", "result", "evidence"]
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "severity": {
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "location": { "type": "string" },
          "scenario": { "type": "string" }
        },
        "required": ["severity", "location", "scenario"]
      }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next": { "type": "string" }
  },
  "required": [
    "role",
    "status",
    "summary",
    "worktree",
    "base",
    "head",
    "commit",
    "git_status",
    "diffstat",
    "patch_sha256",
    "model_report_trust",
    "scope",
    "oracle",
    "red",
    "green",
    "sanitizers",
    "artifacts",
    "checks",
    "findings",
    "risks",
    "next"
  ]
}
