{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "status": {
      "enum": ["complete", "blocked"]
    },
    "summary": { "type": "string" },
    "scope": { "type": "string" },
    "oracle": { "type": "string" },
    "artifacts": { "type": "string" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "kind": { "enum": ["model-tool", "proposed-command"] },
          "tool": {
            "enum": ["Read", "Grep", "Glob", "WebFetch", "WebSearch", "Edit", "Write", "none"]
          },
          "command": { "type": "string" },
          "exit_code": { "type": "integer" },
          "result": { "enum": ["passed", "failed", "not-run"] },
          "evidence": { "type": "string" }
        },
        "required": ["kind", "tool", "command", "exit_code", "result", "evidence"]
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "severity": {
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "location": { "type": "string" },
          "scenario": { "type": "string" }
        },
        "required": ["severity", "location", "scenario"]
      }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next": { "type": "string" }
  },
  "required": [
    "status",
    "summary",
    "scope",
    "oracle",
    "artifacts",
    "checks",
    "findings",
    "risks",
    "next"
  ]
}
